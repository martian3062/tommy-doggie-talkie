{
  "expo": {
    "name": "Dog Translator",
    "slug": "dog-translator",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.dogtranslator.app",
      "permissions": ["CAMERA", "READ_MEDIA_VIDEO", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose videos so Dog Translator can analyze your dog's behavior.",
          "cameraPermission": "Record videos so Dog Translator can analyze your dog's behavior."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "$EXPO_PUBLIC_API_BASE_URL",
      "supabaseUrl": "$EXPO_PUBLIC_SUPABASE_URL"
    }
  }
}
