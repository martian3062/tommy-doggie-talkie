APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./dog_translator.db
LOCAL_MEDIA_DIR=./media
RUN_JOBS_INLINE=true

# Supabase is optional until credentials are provided.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=dog-videos

# Mobile app URL origin, comma-separated if needed.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
